{
  "permissions": {
    "allow": [
      "Bash(python tools/*)",
      "Bash(python .claude/hooks/*)",
      "Bash(powershell tools/*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(python skills/_vendor/tjxj-z-skills/z-excel-editor/scripts/*)",
      "Bash(python skills/_vendor/tjxj-z-skills/z-md-excel/scripts/*)",
      "Bash(pip install:*)",
      "Bash(git:*)",
      "WebSearch",
      "WebFetch",
      "Read",
      "Write",
      "Glob",
      "Grep",
      "Skill",
      "Task",
      "Edit"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/01_session_start.py",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/02_pre_tool_use.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/03_post_tool_use.py",
            "timeout": 20000
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/04_post_tool_use_failure.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/05_stop.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/06_user_prompt_submit.py",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "env": {
    "PKB_ROOT": "<PKB_ROOT>"
  }
}
